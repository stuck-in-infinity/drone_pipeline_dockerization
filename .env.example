# Copy to .env and adjust. All settings use the TCP_ prefix (pydantic-settings).

# ── broker / backend ─────────────────────────────────────────────────
TCP_REDIS_URL=redis://redis:6379/0

# ── storage & database (live on the mounted /data volume) ─────────────
TCP_STORAGE_ROOT=/data/storage
TCP_DATABASE_URL=sqlite:////data/treecrown.db

# ── model catalog (mounted read-only at /models) ─────────────────────
TCP_MODELS_DIR=/models
TCP_MODELS_MANIFEST=/models/models.yaml
TCP_DEFAULT_MODEL_KEY=urban_cambridge

# ── run mode: use the real broker + worker (not inline) ───────────────
TCP_CELERY_EAGER=false

# ── retention cleanup (Celery Beat) ───────────────────────────────────
TCP_RETENTION_DAYS=7
TCP_CLEANUP_ENABLED=true
TCP_CLEANUP_HOUR=3
TCP_CLEANUP_MINUTE=0

# ── uploads / auth (optional) ─────────────────────────────────────────
TCP_MAX_UPLOAD_MB=8192
# TCP_API_KEY=change-me
